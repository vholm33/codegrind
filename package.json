{
    "name": "codegrind",
    "version": "1.0.0",
    "description": "",
    "homepage": "https://github.com/vholm33/codegrind#readme",
    "bugs": {
        "url": "https://github.com/vholm33/codegrind/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vholm33/codegrind.git"
    },
    "license": "ISC",
    "author": "",
    "type": "module",
    "workspaces": [
        "apps/api/",
        "apps/web/",
        "apps/shared/"
    ],
    "scripts": {
        "dev": "concurrently --prefix-colors \"cyan,yellow\" --names \"[BACK],[FRONT]\" \"npm run dev:front\" \"npm run dev:back\"",
        "dev:back": "npm run dev --workspace=api",
        "dev:front": "npm run dev --workspace=web",
        "build": "concurrently --prefix-colors \"cyan,yellow\" --names \"[BACK],[FRONT]\" \"npm run build:front\" \"npm run build:back\"",
        "build:back": "npm run build --workspace=api",
        "build:front": "npm run build --workspace=web",
        "build:shared": "npm run build --workspace=shared",
        "start": "npm run start --workspace=api",
        "start:back": "npm run start --workspace=api"
    },
    "dependencies": {
        "concurrently": "^9.2.1"
    }
}
